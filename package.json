{
  "name": "llm-wiki",
  "version": "0.1.0",
  "description": "Personal LLM knowledge engine — turns questions into a growing wiki",
  "bin": {
    "wiki": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "commander": "14.0.3",
    "gray-matter": "4.0.3",
    "js-yaml": "4.1.1",
    "minisearch": "7.2.0",
    "remark": "15.0.1",
    "slugify": "1.6.9",
    "unified": "11.0.5",
    "write-file-atomic": "7.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "latest",
    "@types/node": "latest",
    "@types/write-file-atomic": "latest",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
