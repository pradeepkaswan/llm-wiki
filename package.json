{
  "name": "llm-wiki",
  "version": "0.1.0",
  "description": "Personal LLM knowledge engine — turns questions into a growing wiki",
  "bin": {
    "wiki": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/",
    "skills/",
    "package.json"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/openai": "^3.0.50",
    "@clack/prompts": "1.2.0",
    "@mozilla/readability": "^0.6.0",
    "ai": "^6.0.146",
    "commander": "14.0.3",
    "exa-js": "^2.11.0",
    "gray-matter": "4.0.3",
    "js-yaml": "4.1.1",
    "jsdom": "^29.0.1",
    "minisearch": "7.2.0",
    "ollama-ai-provider": "^1.2.0",
    "pdf-parse": "^2.4.5",
    "remark": "15.0.1",
    "slugify": "1.6.9",
    "turndown": "^7.2.4",
    "unified": "11.0.5",
    "write-file-atomic": "7.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "latest",
    "@types/jsdom": "^28.0.1",
    "@types/node": "latest",
    "@types/pdf-parse": "^1.1.5",
    "@types/turndown": "^5.0.6",
    "@types/write-file-atomic": "latest",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
